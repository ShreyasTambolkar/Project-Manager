# ─── Database ───
DB_HOST=localhost
DB_NAME=project_db
DB_USER=root
DB_PASSWORD=your_password
DB_PORT=3306

# ─── Microservice Ports ───
AUTH_PORT=5000
STATS_PORT=5001
CHARTS_PORT=5002
LISTING_PORT=5003
CREATE_PORT=5004

# ─── Mail Settings (Gmail SMTP) ───
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ─── Server Config ───
HOST=0.0.0.0

# ─── Frontend ───
FRONTEND_URL=http://localhost:5173

# ─── Frontend API URLs (used by Vite) ───
VITE_API_URL=http://localhost:5000
VITE_STATS_API_URL=http://localhost:5001
VITE_CHARTS_API_URL=http://localhost:5002
VITE_LISTING_API_URL=http://localhost:5003
VITE_CREATE_API_URL=http://localhost:5004
